# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Login credentials (change these in production)
AUTH_EMAIL=admin@vezzt.com
AUTH_PASSWORD=changeme

# Supabase — from Project Settings → Connect → Next.js
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Seed script — database password from Supabase → Settings → Database
SUPABASE_DATABASE_PASS=
# Optional: secret/service role key for REST-based seeding (Settings → API Keys)
# SUPABASE_SECRET_KEY=
# Optional direct connection string override for seed script
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Apify — from Console → Settings → Integrations
APIFY_TOKEN=
APIFY_DEFAULT_API_TOKEN=
# Webhook shared secret for POST /api/apify/run-complete
APIFY_WEBHOOK_SECRET=

# Qualification — min Google reviews for main Vezzt dataset (default 50)
# VEZZT_MIN_REVIEW_COUNT=50

# Collection market (used by scrape/import scripts)
# VEZZT_MARKET=boise-metro
